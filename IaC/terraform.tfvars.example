# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

# Your SSH public key (the contents of e.g. ~/.ssh/id_ed25519.pub).
# A key pair is created from this in each region.
public_key = "ssh-ed25519 AAAA... you@host"

# Lock SSH to your own IP. Find it with:  curl -s https://checkip.amazonaws.com
allowed_ssh_cidr = "203.0.113.7/32"

# Web exposure. With Route 53 (DNS failover, no proxy) clients hit Traefik
# directly and Route 53 health checkers probe /health from public IPs, so keep
# this open.
allowed_http_cidrs = ["0.0.0.0/0"]

# Tailscale ephemeral auth key. REQUIRED for the automatic app deploy: nodes
# address each other by MagicDNS name so etcd/Patroni self-assemble at boot.
# Use a short-lived, pre-approved, tagged key. Stored in user-data.
tailscale_auth_key = "tskey-auth-xxxxxxxx"

# git repo cloned on each server to auto-deploy the stack (must contain
# testing/mock-app). With this + the Tailscale key set, ONLY Route 53 is left
# after apply. Leave "" to deploy the stack by hand instead.
mock_app_repo = "https://github.com/you/geerd-ha-failover.git"

# --- Regions (A and B should be ~10 ms apart for prod; witness independent) ---
region_a       = "eu-west-3"    # primary
region_b       = "eu-central-1" # warm standby
region_witness = "eu-west-1"    # quorum witness

# --- Option A (default): automatic failover with an etcd quorum, RPO ~ 0 ---
# etcd runs on every app server; the witness is the third vote / tie-breaker.
# Set enable_witness = false for Option B (streaming replication + scripted
# promotion, no automatic quorum) — drops the witness.
enable_witness = true

# --- Deploy through Dokploy (prod-faithful) instead of raw docker compose ---
# true  = register + deploy the stack as a Dokploy Compose app at boot (rides
#         Dokploy's headless API; may need a /swagger tweak — see NEXT_STEPS).
# false = plain `docker compose up` at boot (reliable; identical containers).
deploy_via_dokploy  = false
dokploy_admin_email = "admin@ha-mock.local"

# --- Sizing (mock app + local Dokploy co-resident -> needs ~4 GB) ---
app_count             = 3
app_instance_type     = "t3.medium" # 2 vCPU / 4 GB + 2 GB swap
witness_instance_type = "t3.micro"
data_volume_gb        = 10
root_volume_gb        = 20
