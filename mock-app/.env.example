# Per-NODE values. Terraform writes this automatically on each server (from the
# node's identity + the shared cluster list). Shown here for manual deploys.
#
# Cross-node addressing uses Tailscale MagicDNS *names* (app-a1, app-b1, witness…)
# so nothing needs to know IPs at boot. NODE_MESH_IP holds THIS node's name.

# ---- identity (differs per node) ----
REGION=region-a                 # region-a on app-a1, region-b on app-b1
PATRONI_NAME=app-a1             # this node's name: app-a1 / app-b1
ETCD_NAME=app-a1                # etcd member name = node name
NODE_MESH_IP=app-a1             # THIS node's Tailscale MagicDNS name

# ---- Patroni pair scope (same on the two members of a DB pair) ----
# app-a1 + app-b1 -> app1  (single-app topology; more pairs -> app2, app3, …)
PATRONI_SCOPE=app1
ETCD3_HOSTS=127.0.0.1:2379      # Patroni talks to the local etcd member

# ---- etcd cluster (IDENTICAL on all 3 nodes; MagicDNS names) ----
ETCD_INITIAL_CLUSTER=app-a1=http://app-a1:2380,app-b1=http://app-b1:2380,witness=http://witness:2380
ETCD_INITIAL_CLUSTER_STATE=new  # 'new' for the initial bring-up; 'existing' when adding a node later
ETCD_TOKEN=ha-mock-etcd

# ---- Postgres credentials (IDENTICAL across a pair; simplest: same everywhere) ----
PG_SUPERUSER=postgres
PG_SUPERUSER_PASSWORD=change-me-super
PG_REPL_USER=replicator
PG_REPL_PASSWORD=change-me-repl
